##############################################################################
# ACCOUNT CONFIGURATION
##############################################################################

prod_account_id        = "111111111111"
dev_account_id         = "222222222222"
operations_account_id  = "333333333333"

prod_account_aws_profile       = "pl-pathfinder-starting-user-prod"
dev_account_aws_profile        = "pl-pathfinder-starting-user-dev"
operations_account_aws_profile = "pl-pathfinder-starting-user-operations"

# Optional: For OIDC-GitHub challenge
# github_repo = "your-org/your-repo"

##############################################################################
# SCENARIO ENABLEMENT
# Set to true to enable a scenario, false to disable
##############################################################################

# PROD ONE-HOP TO-ADMIN
enable_prod_one_hop_to_admin_iam_putrolepolicy      = false
enable_prod_one_hop_to_admin_iam_attachrolepolicy   = false
enable_prod_one_hop_to_admin_iam_createpolicyversion = false
enable_prod_one_hop_to_admin_iam_createaccesskey     = false

# PROD ONE-HOP TO-BUCKET
enable_prod_one_hop_to_bucket_iam_putrolepolicy          = false
enable_prod_one_hop_to_bucket_iam_attachrolepolicy       = false
enable_prod_one_hop_to_bucket_iam_createaccesskey        = false
enable_prod_one_hop_to_bucket_iam_updateassumerolepolicy = false
enable_prod_one_hop_to_bucket_iam_assumerole             = false

# PROD MULTI-HOP TO-ADMIN
enable_prod_multi_hop_to_admin_putrolepolicy_on_other  = false
enable_prod_multi_hop_to_admin_multiple_paths_combined = false

# PROD MULTI-HOP TO-BUCKET
enable_prod_multi_hop_to_bucket_role_chain_to_s3         = false
enable_prod_multi_hop_to_bucket_resource_policy_bypass   = false
enable_prod_multi_hop_to_bucket_exclusive_resource_policy = false

# PROD TOXIC-COMBO
enable_prod_toxic_combo_public_lambda_with_admin = false

# CROSS-ACCOUNT DEV-TO-PROD
enable_cross_account_dev_to_prod_one_hop_simple_role_assumption    = false
enable_cross_account_dev_to_prod_multi_hop_passrole_lambda_admin   = false
enable_cross_account_dev_to_prod_multi_hop_multi_hop_both_sides    = false
enable_cross_account_dev_to_prod_multi_hop_lambda_invoke_update    = false

# CROSS-ACCOUNT OPS-TO-PROD
enable_cross_account_ops_to_prod_one_hop_simple_role_assumption = false
